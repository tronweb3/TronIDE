# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored; never commit real secrets.

# GitHub personal access token used by e2e tests that exercise the Gist feature.
# Required only if you run the gist-related e2e suites.
gist_token=<token>

# Ethereum account credentials used by e2e tests that deploy from an unlocked account.
# Required only if you run `runAndDeploy` e2e tests.
account_passphrase=<passphrase>
account_password=<password>

# Raises Node heap size for memory-heavy builds (webpack, nx).
# Optional — keep the default if your machine has enough RAM.
NODE_OPTIONS=--max-old-space-size=2048

# Public TronGrid API key inlined into the IDE bundle at build time.
# Optional. When unset, the IDE falls back to anonymous TronGrid rate limits.
# This value is readable by every browser user of the built app, so only use a
# low-privilege key restricted by referrer/origin in TronGrid. Do not use
# TRON_PRO_API_KEY or any privileged server-side key in frontend builds.
TRON_PUBLIC_TRONGRID_API_KEY=

# Optional comma-separated TronScan contract status API overrides.
# Each value is public frontend config. Defaults are used when unset.
TRONSCAN_MAINNET_CONTRACT_API_URLS=
TRONSCAN_NILE_CONTRACT_API_URLS=
TRONSCAN_SHASTA_CONTRACT_API_URLS=
