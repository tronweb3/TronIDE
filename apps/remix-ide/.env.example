# Copy this file to `.env` in the same directory and fill in your own values.
# `.env` is git-ignored; never commit real secrets.
#
# Used by e2e tests under apps/remix-ide-e2e. Only required if you run
# the Gist or runAndDeploy suites locally.

gist_token=<token>
account_passphrase=<passphrase>
account_password=<password>
