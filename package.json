{
  "name": "tronide",
  "version": "2.3.0",
  "remixVersion": "0.16.2",
  "license": "Apache-2.0 AND MIT",
  "description": "Tron IDE Monorepo",
  "keywords": [
    "tron",
    "tronide",
    "ethereum",
    "solidity",
    "compiler"
  ],
  "engines": {
    "node": "20.19.2",
    "pnpm": "10.12.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tronweb3/TronIDE.git"
  },
  "author": "Tron IDE Team",
  "bugs": {
    "url": "https://github.com/tronweb3/TronIDE/issues"
  },
  "homepage": "https://github.com/tronweb3/TronIDE#readme",
  "bin": {
    "remix-ide": "./apps/remix-ide/bin/remix-ide"
  },
  "scripts": {
    "postinstall": "npm run build:libs && npm run downloadsolc_assets && npm run setup-hooks",
    "setup-hooks": "node -e \"try { require('child_process').execSync('bash .githooks/setup.sh', { stdio: 'inherit' }) } catch (e) { console.log('[setup-hooks] skipped (bash unavailable or setup failed):', e.message) }\"",
    "nx": "nx",
    "start": "nx start",
    "serve": "nx serve",
    "build": "nx build",
    "build:prod": "nx build --prod",
    "test": "nx test",
    "lint": "nx lint",
    "affected:apps": "nx affected:apps",
    "affected:libs": "nx affected:libs",
    "affected:build": "nx affected:build",
    "affected:test": "nx affected:test",
    "affected:lint": "nx affected:lint",
    "affected:dep-graph": "nx affected:dep-graph",
    "affected": "nx affected",
    "format": "nx format:write",
    "format:write": "nx format:write",
    "format:check": "nx format:check",
    "update": "nx migrate latest",
    "workspace-schematic": "nx workspace-schematic",
    "dep-graph": "nx dep-graph",
    "help": "nx help",
    "lint:libs": "nx run-many --target=lint --projects=remix-analyzer,remix-astwalker,remix-debug,remix-lib,remix-simulator,remix-solidity,remix-tests,remix-url-resolver,remixd,remix-ui-tree-view,remix-ui-modal-dialog,remix-ui-toaster,remix-ui-file-explorer,remix-ui-debugger-ui,remix-ui-workspace,remix-ui-static-analyser,remix-ui-checkbox,remix-ui-settings,remix-core-plugin,remix-ui-renderer,remix-ui-publish-to-storage,remix-ui-solidity-compiler",
    "lint:remix-analyzer-typecheck": "node ./node_modules/typescript/bin/tsc -p libs/remix-analyzer/tsconfig.lib.json --noEmit --rootDir . --skipLibCheck",
    "build:libs": "nx run-many --target=build --parallel=false --with-deps=true --projects=remix-analyzer,remix-astwalker,remix-debug,remix-lib,remix-simulator,remix-solidity,remix-tests,remix-url-resolver,remixd",
    "build:remix-lib": "nx run remix-lib:build",
    "build:remix-simulator": "nx run remix-simulator:build",
    "test:libs": "NODE_OPTIONS=\"--max-old-space-size=4096\" nx run-many --target=test --projects=remix-analyzer,remix-astwalker,remix-debug,remix-lib,remix-simulator,remix-tests,remix-url-resolver,remixd",
    "publish:libs": "npm run build:libs && lerna publish --skip-git && npm run bumpVersion:libs",
    "build:e2e": "tsc -p apps/remix-ide-e2e/tsconfig.e2e.json",
    "watch:e2e": "nodemon",
    "test:pw": "playwright test --config apps/remix-ide-pw/playwright.config.ts",
    "test:pw:headed": "playwright test --config apps/remix-ide-pw/playwright.config.ts --headed",
    "test:pw:debug": "playwright test --config apps/remix-ide-pw/playwright.config.ts --debug",
    "test:pw:install": "playwright install --with-deps chromium",
    "bumpVersion:libs": "gulp & gulp syncLibVersions;",
    "browsertest": "sleep 5 && npm run nightwatch_local",
    "csslint": "csslint --ignore=order-alphabetical --errors='errors,duplicate-properties,empty-rules' --exclude-list='apps/remix-ide/src/assets/css/font-awesome.min.css' apps/remix-ide/src/assets/css/",
    "downloadsolc_assets": "curl -L https://binaries.soliditylang.org/wasm/soljson-v0.8.20+commit.a1b79de6.js -o ./apps/remix-ide/src/assets/js/soljson.js",
    "make-mock-compiler": "node apps/remix-ide/ci/makeMockCompiler.js",
    "minify": "uglifyjs --in-source-map inline --source-map-inline -c warnings=false",
    "nightwatch_parallel": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js --env=chrome,firefox",
    "e2e:golden:run": "nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/usingWebWorker.test.js build/apps/remix-ide-e2e/src/tests/compilerSourceError.spec.js build/apps/remix-ide-e2e/src/tests/ballot.test.js build/apps/remix-ide-e2e/src/tests/transactionExecution.spec.js build/apps/remix-ide-e2e/src/tests/trc10Execution.spec.js build/apps/remix-ide-e2e/src/tests/libraryDeployment.test.js build/apps/remix-ide-e2e/src/tests/debugger.spec.js build/apps/remix-ide-e2e/src/tests/workspace.test.js build/apps/remix-ide-e2e/src/tests/globalSearch.spec.js build/apps/remix-ide-e2e/src/tests/fileExplorer.test.js build/apps/remix-ide-e2e/src/tests/landingQuickStart.spec.js build/apps/remix-ide-e2e/src/tests/pluginManager.spec.js --env=chrome",
    "e2e:golden:wait-and-run": "until curl -sf http://127.0.0.1:8080/ >/dev/null 2>&1; do sleep 2; done && pnpm e2e:golden:run",
    "e2e:golden": "pnpm build:libs && pnpm build:e2e && pnpm selenium-install && npm-run-all -lpr selenium serve e2e:golden:wait-and-run",
    "nightwatch_local_firefox": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js --env=firefox",
    "nightwatch_local_chrome": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js --env=chrome",
    "nightwatch_local_ballot": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/ballot.test.js --env=chrome",
    "nightwatch_local_ballot_0_4_11": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/ballot_0_4_11.spec.js --env=chrome",
    "nightwatch_local_usingWorker": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/usingWebWorker.test.js build/apps/remix-ide-e2e/src/tests/compilerSourceError.spec.js --env=chrome",
    "nightwatch_local_libraryDeployment": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/libraryDeployment.test.js --env=chrome",
    "nightwatch_local_solidityImport": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/solidityImport.spec.js --env=chrome",
    "nightwatch_local_recorder": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/recorder.spec.js --env=chrome",
    "nightwatch_local_transactionExecution": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/transactionExecution.spec.js --env=chrome",
    "nightwatch_local_trc10Execution": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/trc10Execution.spec.js --env=chrome",
    "nightwatch_local_staticAnalysis": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/staticAnalysis.spec.js --env=chrome",
    "nightwatch_local_signingMessage": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/signingMessage.test.js --env=chrome",
    "nightwatch_local_specialFunctions": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/specialFunctions.test.js --env=chrome",
    "nightwatch_local_solidityUnitTests": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/solidityUnittests.spec.js --env=chrome",
    "nightwatch_local_remixd": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/remixd.test.js --env=chrome",
    "nightwatch_local_terminal": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/terminal.test.js --env=chrome",
    "nightwatch_local_gist": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/gist.spec.js --env=chrome",
    "nightwatch_local_workspace": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/workspace.test.js --env=chrome",
    "nightwatch_local_defaultLayout": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/defaultLayout.test.js --env=chrome",
    "nightwatch_local_pluginManager": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/pluginManager.spec.js --env=chrome",
    "nightwatch_local_publishContract": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/publishContract.test.js --env=chrome",
    "nightwatch_local_generalSettings": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/generalSettings.test.js --env=chrome",
    "nightwatch_local_fileExplorer": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/fileExplorer.test.js --env=chrome",
    "nightwatch_local_debugger": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/debugger.spec.js --env=chrome",
    "nightwatch_local_editor": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/editor.spec.js --env=chrome",
    "nightwatch_local_compiler": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/compiler_api.test.js --env=chrome",
    "nightwatch_local_txListener": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/txListener.test.js --env=chrome",
    "nightwatch_local_fileManager": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/fileManager_api.spec.js --env=chrome",
    "nightwatch_local_runAndDeploy": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/runAndDeploy.js --env=chrome-runAndDeploy",
    "nightwatch_local_url": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/url.spec.js --env=chrome",
    "nightwatch_local_verticalIconscontextmenu": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/verticalIconsPanel.spec.js --env=chrome",
    "onchange": "onchange apps/remix-ide/build/app.js -- npm-run-all lint",
    "remixd": "nx build remixd && nx serve remixd --folder=./apps/remix-ide/contracts --remixide=http://127.0.0.1:8080",
    "selenium": "node scripts/start-matching-selenium.cjs start",
    "selenium-install": "node scripts/start-matching-selenium.cjs install",
    "sourcemap": "exorcist --root ../ apps/remix-ide/build/app.js.map > apps/remix-ide/build/app.js",
    "test-browser": "npm-run-all -lpr selenium make-mock-compiler serve browsertest",
    "watch": "watchify apps/remix-ide/src/index.js -dv -p browserify-reload -o apps/remix-ide/build/app.js --exclude solc",
    "reinstall": "rm ./node-modules/ -rf && rm package-lock.json && rm ./build/ -rf && npm install & npm run build",
    "ganache-cli": "npx ganache-cli",
    "lint:compiler-source": "node scripts/check-compiler-source-consistency.cjs",
    "lint:remix-ide-entry": "node scripts/check-remix-ide-entry-consistency.cjs",
    "licenses:report": "node scripts/generate-license-report.cjs --format text --output THIRD_PARTY_LICENSES.txt",
    "licenses:report:json": "node scripts/generate-license-report.cjs --format json --output THIRD_PARTY_LICENSES.json",
    "nightwatch_local_globalSearch": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/globalSearch.spec.js --env=chrome",
    "nightwatch_local_landingQuickStart": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/landingQuickStart.spec.js --env=chrome",
    "nightwatch_local_landingTronLinkConnect": "npm run build:e2e && nightwatch --config build/apps/remix-ide-e2e/nightwatch.js build/apps/remix-ide-e2e/src/tests/landingTronLinkConnect.spec.js --env=chrome"
  },
  "browserify": {
    "transform": [
      [
        "babelify",
        {
          "sourceMapsAbsolute": false,
          "sourceMaps": true,
          "plugins": [
            [
              "module:fast-async",
              {
                "runtimePattern": null,
                "compiler": {
                  "es7": true,
                  "noRuntime": true,
                  "promises": true,
                  "wrapAwait": true
                }
              }
            ],
            [
              "module:babel-plugin-yo-yoify"
            ],
            [
              "module:@babel/plugin-transform-object-assign"
            ]
          ],
          "presets": [
            "@babel/preset-env"
          ]
        }
      ]
    ]
  },
