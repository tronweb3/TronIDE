#!/usr/bin/env bash
#
# Pre-commit hook: fast security checks by default, optional AI review
# Install: bash .githooks/setup.sh
#

set -euo pipefail

# ─── Runtime options ────────────────────────────────────────────────────────
RUN_AI_REVIEW="${PRE_COMMIT_AI_REVIEW:-0}"

for arg in "$@"; do
    case "$arg" in
        --ai)
            RUN_AI_REVIEW=1
            ;;
        --no-ai)
            RUN_AI_REVIEW=0
            ;;
        --help)
            cat <<'EOF'
Usage: .githooks/pre-commit [--ai] [--no-ai]

Defaults:
  - fast local checks run on every commit
  - AI review is disabled unless PRE_COMMIT_AI_REVIEW=1 or --ai is provided
EOF
            exit 0
            ;;
    esac
done

# ─── Configuration ───────────────────────────────────────────────────────────
REPORT_DIR=".security-reports"
TIMESTAMP=$(date +%Y%m%d_%H%M%S)
SECURITY_REPORT="${REPORT_DIR}/security-${TIMESTAMP}.md"
QUALITY_REPORT="${REPORT_DIR}/quality-${TIMESTAMP}.md"
MAX_REPORTS=20  # keep last N reports, auto-cleanup older ones

# Color output
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# ─── Helpers ─────────────────────────────────────────────────────────────────
info()  { echo -e "${CYAN}[pre-commit]${NC} $*"; }
warn()  { echo -e "${YELLOW}[pre-commit]${NC} $*"; }
error() { echo -e "${RED}[pre-commit]${NC} $*"; }
ok()    { echo -e "${GREEN}[pre-commit]${NC} $*"; }

# ─── Collect staged files ───────────────────────────────────────────────────
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

# Filter to JS/TS/JSON/env files
CODE_FILES=$(echo "$STAGED_FILES" | grep -E '\.(js|ts|jsx|tsx)$' || true)
CONFIG_FILES=$(echo "$STAGED_FILES" | grep -E '\.(json|ya?ml|env.*)$' || true)
ALL_TARGET_FILES=$(echo -e "${CODE_FILES}\n${CONFIG_FILES}" | grep -v '^$' | sort -u || true)

if [ -z "$ALL_TARGET_FILES" ]; then
    info "No JS/TS/JSON/env files staged — skipping review."
    exit 0
fi

FILE_COUNT=$(echo "$ALL_TARGET_FILES" | wc -l | tr -d ' ')
info "Found ${FILE_COUNT} staged file(s) to review:"
echo "$ALL_TARGET_FILES" | sed 's/^/  /'

# ─── Phase 1: Quick pattern-based checks (fast, no AI) ─────────────────────
info "Phase 1: Quick pattern scan..."

QUICK_ISSUES=0
QUICK_BLOCKING_ISSUES=0

# Check for hardcoded private keys / mnemonics
if echo "$ALL_TARGET_FILES" | xargs grep -nE '(private[_-]?key|mnemonic|seed[_-]?phrase)\s*[:=]\s*["\x27]' 2>/dev/null; then
    error "CRITICAL: Possible hardcoded private key or mnemonic detected!"
    QUICK_ISSUES=$((QUICK_ISSUES + 1))
    QUICK_BLOCKING_ISSUES=$((QUICK_BLOCKING_ISSUES + 1))
fi

# Check for console.log with sensitive-looking data
if echo "$CODE_FILES" | xargs grep -nE 'console\.(log|debug|info)\s*\(.*\b(private|secret|password|mnemonic|seed|token|apiKey|api_key)\b' 2>/dev/null; then
    warn "WARNING: console.log may leak sensitive data"
    QUICK_ISSUES=$((QUICK_ISSUES + 1))
fi

# Check for common API key patterns
if echo "$ALL_TARGET_FILES" | xargs grep -nE '(sk-[a-zA-Z0-9]{20,}|AKIA[0-9A-Z]{16}|ghp_[a-zA-Z0-9]{36}|xox[bpras]-[a-zA-Z0-9-]+)' 2>/dev/null; then
    error "CRITICAL: Possible API key/token detected in staged files!"
    QUICK_ISSUES=$((QUICK_ISSUES + 1))
    QUICK_BLOCKING_ISSUES=$((QUICK_BLOCKING_ISSUES + 1))
fi

# Check for eval and dangerous functions
if [ -n "$CODE_FILES" ]; then
    if echo "$CODE_FILES" | xargs grep -nE '\beval\s*\(|new\s+Function\s*\(' 2>/dev/null; then
        warn "WARNING: eval() or new Function() detected — potential code injection risk"
        QUICK_ISSUES=$((QUICK_ISSUES + 1))
    fi
fi

# Check for .env files being committed
if echo "$STAGED_FILES" | grep -E '\.env($|\.)' | grep -v '\.env\.example' | grep -v '\.env\.template'; then
    error "CRITICAL: .env file is being committed! This may contain secrets."
    QUICK_ISSUES=$((QUICK_ISSUES + 1))
    QUICK_BLOCKING_ISSUES=$((QUICK_BLOCKING_ISSUES + 1))
fi

if [ "$QUICK_ISSUES" -gt 0 ]; then
    warn "Quick scan found ${QUICK_ISSUES} potential issue(s)."
else
    ok "Quick scan: clean"
fi

# ─── Decide whether AI review should run ────────────────────────────────────
if [ "$RUN_AI_REVIEW" != "1" ]; then
    info "AI review disabled for pre-commit. Use PRE_COMMIT_AI_REVIEW=1 or --ai to enable it."
fi

# ─── Prepare diff context for optional AI review ────────────────────────────
STAGED_DIFF=""
if [ "$RUN_AI_REVIEW" = "1" ]; then
    STAGED_DIFF=$(git diff --cached)
fi

# ─── Optional AI-powered security review ────────────────────────────────────
if [ "$RUN_AI_REVIEW" = "1" ]; then
    if ! command -v claude &>/dev/null; then
        warn "Claude Code CLI not found. Skipping AI review."
    else
        mkdir -p "$REPORT_DIR"

        info "Phase 2: Security code review (Claude Code)..."

        SECURITY_SKILL=$(cat .claude/skills/security-code-review.md 2>/dev/null || echo "Perform a security code review on the staged changes.")
        SECURITY_EXIT=0
        echo "${SECURITY_SKILL}

Here are the staged changes to review:

\`\`\`
${STAGED_DIFF}
\`\`\`" | claude -p --output-format text > "$SECURITY_REPORT" 2>/dev/null || SECURITY_EXIT=$?

        if [ "$SECURITY_EXIT" -ne 0 ]; then
            warn "Security review exited with code ${SECURITY_EXIT}. Check ${SECURITY_REPORT} if it exists."
        fi

        info "Phase 3: Code quality review (Claude Code)..."

        QUALITY_SKILL=$(cat .claude/skills/code-quality-review.md 2>/dev/null || echo "Perform a code quality review on the staged changes.")
        QUALITY_EXIT=0
        echo "${QUALITY_SKILL}

Here are the staged changes to review:

\`\`\`
${STAGED_DIFF}
\`\`\`" | claude -p --output-format text > "$QUALITY_REPORT" 2>/dev/null || QUALITY_EXIT=$?

        if [ "$QUALITY_EXIT" -ne 0 ]; then
            warn "Quality review exited with code ${QUALITY_EXIT}. Check ${QUALITY_REPORT} if it exists."
        fi
    fi
fi

# ─── Parse results & decide ─────────────────────────────────────────────────
BLOCK_COMMIT=false

# Block immediately on fast critical findings
if [ "$QUICK_BLOCKING_ISSUES" -gt 0 ]; then
    error "Quick scan found ${QUICK_BLOCKING_ISSUES} blocking issue(s)."
    BLOCK_COMMIT=true
fi

# Check security report for CRITICAL findings
if [ -f "$SECURITY_REPORT" ]; then
    CRITICAL_COUNT=$(grep -c '\[CRITICAL\]' "$SECURITY_REPORT" 2>/dev/null) || CRITICAL_COUNT=0
    HIGH_COUNT=$(grep -c '\[HIGH\]' "$SECURITY_REPORT" 2>/dev/null) || HIGH_COUNT=0

    if [ "$CRITICAL_COUNT" -gt 0 ]; then
        error "Security review found ${CRITICAL_COUNT} CRITICAL issue(s)!"
        error "Review report: ${SECURITY_REPORT}"
        BLOCK_COMMIT=true
    fi

    if [ "$HIGH_COUNT" -gt 0 ]; then
        warn "Security review found ${HIGH_COUNT} HIGH severity issue(s)."
        warn "Review report: ${SECURITY_REPORT}"
    fi
fi

# Check quality report
if [ -f "$QUALITY_REPORT" ]; then
    Q_HIGH_COUNT=$(grep -c '\[HIGH\]' "$QUALITY_REPORT" 2>/dev/null) || Q_HIGH_COUNT=0

    if [ "$Q_HIGH_COUNT" -gt 0 ]; then
        warn "Quality review found ${Q_HIGH_COUNT} HIGH severity issue(s)."
        warn "Review report: ${QUALITY_REPORT}"
    fi
fi

# ─── Cleanup old reports ────────────────────────────────────────────────────
if [ -d "$REPORT_DIR" ]; then
    REPORT_COUNT=$(ls -1 "$REPORT_DIR"/*.md 2>/dev/null | wc -l | tr -d ' ')
    if [ "$REPORT_COUNT" -gt "$MAX_REPORTS" ]; then
        ls -1t "$REPORT_DIR"/*.md | tail -n +$((MAX_REPORTS + 1)) | xargs rm -f
        info "Cleaned up old reports (kept last ${MAX_REPORTS})"
    fi
fi

# ─── Final decision ─────────────────────────────────────────────────────────
echo ""
if [ "$BLOCK_COMMIT" = true ]; then
    error "=========================================="
    error "  COMMIT BLOCKED — CRITICAL issues found  "
    error "=========================================="
    error ""
    error "Fix the blocking issues above before committing."
    if [ -d "$REPORT_DIR" ]; then
        error "Reports saved to: ${REPORT_DIR}/"
    fi
    error ""
    error "To bypass (NOT recommended): git commit --no-verify"
    exit 1
fi

ok "=========================================="
ok "  Review complete — no blocking issues    "
ok "=========================================="
if [ "$RUN_AI_REVIEW" = "1" ] && [ -d "$REPORT_DIR" ]; then
    ok "Reports saved to: ${REPORT_DIR}/"
fi
exit 0
